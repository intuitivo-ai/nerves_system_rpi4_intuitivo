+static GgBuffer read_device_architecture_detail(void) {
+    static uint8_t buf[64];
+    static GgBuffer cached = { 0 };
+    static bool read_done = false;
+
+    if (read_done) {
+        return cached;
+    }
+    read_done = true;
+
+    GgArena alloc = gg_arena_init(GG_BUF(buf));
+    GgObject obj;
+    GgError ret = ggl_gg_config_read(
+        GG_BUF_LIST(
+            GG_STR("services"),
+            GG_STR("aws.greengrass.NucleusLite"),
+            GG_STR("configuration"),
+            GG_STR("platformOverride"),
+            GG_STR("architecture.detail")
+        ),
+        &alloc,
+        &obj
+    );
+    if (ret == GG_ERR_OK && gg_obj_type(obj) == GG_TYPE_BUF) {
+        cached = gg_obj_into_buf(obj);
+    }
+    return cached;
+}
